// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Orientation {
  LANDSCAPE
  PORTRAIT
}

enum AssetType {
  IMAGE
  VIDEO
}

enum AssetStatus {
  PROCESSING
  READY
  FAILED
}

/* --- Campaigns --- */
enum CampaignStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum CampaignTargetType {
  SCREEN
  GROUP
}

/* --- Structured vendor input --- */
enum ContentCollectionType {
  MENU
  DROPS
  EVENTS
}

enum ContentEntryStatus {
  DRAFT
  APPROVED
  ARCHIVED
}

/* --- Playlist widgets --- */
enum PlaylistItemKind {
  ASSET
  COLLECTION_WIDGET
}

enum WidgetRenderMode {
  TICKER
  LIST
  GRID
}

model Screen {
  id              String   @id @default(cuid())
  screenNumber    Int      @unique
  name            String

  deviceId        String?  @unique
  activationCode  String   @unique
  orientation     Orientation
  width           Int
  height          Int
  timezone        String   @default("America/Phoenix")
  lastSeenAt      DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  schedules       ScheduleWindow[]
  logs            ProofOfPlayLog[]

  groupMembers    ScreenGroupMember[]
  campaignTargets CampaignTarget[]
}

model ScreenGroup {
  id              String   @id @default(cuid())
  name            String
  description     String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         ScreenGroupMember[]
  campaignTargets CampaignTarget[]
}

model ScreenGroupMember {
  id        String   @id @default(cuid())

  groupId   String
  group     ScreenGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  screenId  String
  screen    Screen      @relation(fields: [screenId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([groupId, screenId])
  @@index([screenId])
}

model Asset {
  id            String      @id @default(cuid())
  name          String
  type          AssetType
  orientation   Orientation
  masterUrl     String
  status        AssetStatus @default(PROCESSING)
  durationSec   Int?

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  renditions    AssetRendition[]
  playlistItems PlaylistItem[]
  logs          ProofOfPlayLog[]

  contentEntries ContentEntry[]
}

model AssetRendition {
  id        String   @id @default(cuid())

  assetId   String
  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  url       String
  width     Int
  height    Int
  codec     String?
  bitrate   Int?
  filesize  Int?

  createdAt DateTime @default(now())
}

model Playlist {
  id        String   @id @default(cuid())
  name      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items     PlaylistItem[]
  schedules ScheduleWindow[]
  campaigns Campaign[]
}

model PlaylistItem {
  id           String   @id @default(cuid())

  playlistId   String
  playlist     Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  // ASSET item
  assetId      String?
  asset        Asset?   @relation(fields: [assetId], references: [id], onDelete: Cascade)

  // COLLECTION_WIDGET item
  collectionId String?
  collection   ContentCollection? @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  kind         PlaylistItemKind   @default(ASSET)
  renderMode   WidgetRenderMode?

  sortOrder    Int      @default(0)
  durationSec  Int?

  createdAt    DateTime @default(now())

  @@index([playlistId, sortOrder])
  @@index([collectionId])
}

model Campaign {
  id          String         @id @default(cuid())
  name        String
  description String?
  status      CampaignStatus @default(DRAFT)

  timezone    String         @default("America/Phoenix")
  priority    Int            @default(10)
  startAt     DateTime
  endAt       DateTime

  playlistId  String
  playlist    Playlist       @relation(fields: [playlistId], references: [id], onDelete: Restrict)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  targets     CampaignTarget[]
  schedules   ScheduleWindow[]

  @@index([status, startAt, endAt])
}

model CampaignTarget {
  id          String             @id @default(cuid())
  type        CampaignTargetType

  campaignId  String
  campaign    Campaign           @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  // Exactly one of these is set, depending on type
  screenId    String?
  screen      Screen?            @relation(fields: [screenId], references: [id], onDelete: Cascade)

  groupId     String?
  group       ScreenGroup?       @relation(fields: [groupId], references: [id], onDelete: Cascade)

  createdAt   DateTime           @default(now())

  @@index([campaignId])
  @@index([screenId])
  @@index([groupId])
}

model ScheduleWindow {
  id          String   @id @default(cuid())

  screenId    String
  screen      Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  playlistId  String
  playlist    Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)

  campaignId  String?
  campaign    Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  priority    Int      @default(10)
  startAt     DateTime
  endAt       DateTime

  createdAt   DateTime @default(now())

  @@index([screenId, startAt, endAt])
  @@index([campaignId])
  @@unique([campaignId, screenId])
}

model ProofOfPlayLog {
  id          String   @id @default(cuid())

  screenId    String
  screen      Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)

  assetId     String
  asset       Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  startedAt   DateTime
  endedAt     DateTime
  durationSec Int

  createdAt   DateTime @default(now())

  @@index([screenId, createdAt])
  @@index([assetId, createdAt])
}

model ContentCollection {
  id          String               @id @default(cuid())
  name        String
  type        ContentCollectionType
  description String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  entries     ContentEntry[]
  playlistItems PlaylistItem[]
}

model ContentEntry {
  id            String             @id @default(cuid())
  collectionId  String
  collection    ContentCollection  @relation(fields: [collectionId], references: [id], onDelete: Cascade)

  title         String
  body          String?
  status        ContentEntryStatus @default(DRAFT)

  startAt       DateTime?
  endAt         DateTime?

  assetId       String?
  asset         Asset?             @relation(fields: [assetId], references: [id], onDelete: SetNull)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([collectionId, status])
  @@index([startAt, endAt])
}